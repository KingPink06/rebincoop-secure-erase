<?xml version="1.0" encoding="UTF-8"?>
<!--
  Minimal Openbox config for REBINCOOP kiosk.
  - No desktop right-click menu
  - No taskbar / dock
  - Chromium always fullscreen, no decorations
  - All keyboard shortcuts disabled (kiosk hardening)
-->
<openbox_config xmlns="http://openbox.org/3.4/rc"
                xmlns:xi="http://www.w3.org/2001/XInclude">

  <resistance>
    <strength>10</strength>
    <screen_edge_strength>20</screen_edge_strength>
  </resistance>

  <focus>
    <focusNew>yes</focusNew>
    <followMouse>no</followMouse>
    <focusLast>yes</focusLast>
    <underMouse>no</underMouse>
    <focusDelay>200</focusDelay>
    <raiseOnFocus>no</raiseOnFocus>
  </focus>

  <placement>
    <policy>Smart</policy>
    <center>yes</center>
    <monitor>Primary</monitor>
    <primaryMonitor>1</primaryMonitor>
  </placement>

  <theme>
    <name>Clearlooks</name>
    <titleLayout>NLIMC</titleLayout>
    <keepBorder>yes</keepBorder>
    <animateIconify>no</animateIconify>
    <font place="ActiveWindow">
      <name>Sans</name><size>10</size><weight>Bold</weight><slant>Normal</slant>
    </font>
    <font place="InactiveWindow">
      <name>Sans</name><size>10</size><weight>Bold</weight><slant>Normal</slant>
    </font>
  </theme>

  <desktops>
    <number>1</number>
    <firstdesk>1</firstdesk>
    <names><name>REBINCOOP</name></names>
    <popupTime>875</popupTime>
  </desktops>

  <resize>
    <drawContents>yes</drawContents>
    <popupShow>Nonpixel</popupShow>
    <popupPosition>Center</popupPosition>
    <popupFixedPosition><x>10</x><y>10</y></popupFixedPosition>
  </resize>

  <margins>
    <top>0</top><bottom>0</bottom><left>0</left><right>0</right>
  </margins>

  <!-- All keyboard shortcuts disabled for kiosk hardening -->
  <keyboard>
    <chainQuitKey>C-g</chainQuitKey>
    <!-- No shortcuts defined -->
  </keyboard>

  <!-- No mouse bindings on desktop (disable right-click menu) -->
  <mouse>
    <dragThreshold>1</dragThreshold>
    <doubleClickTime>200</doubleClickTime>
    <screenEdgeWarpTime>0</screenEdgeWarpTime>
    <screenEdgeWarpMouse>false</screenEdgeWarpMouse>
    <context name="Desktop"><!-- intentionally empty --></context>
    <context name="Root"><!-- intentionally empty --></context>
    <context name="Client">
      <mousebind button="Left" action="Press">
        <action name="Focus"/>
        <action name="Raise"/>
      </mousebind>
    </context>
    <context name="Titlebar">
      <mousebind button="Left" action="Drag">
        <action name="Move"/>
      </mousebind>
    </context>
  </mouse>

  <!-- Chromium: always fullscreen, no window decorations -->
  <applications>
    <application class="Chromium-browser" name="chromium-browser">
      <decor>no</decor>
      <fullscreen>yes</fullscreen>
      <maximized>yes</maximized>
      <focus>yes</focus>
      <layer>normal</layer>
      <desktop>1</desktop>
    </application>
    <application class="Chromium" name="chromium">
      <decor>no</decor>
      <fullscreen>yes</fullscreen>
      <maximized>yes</maximized>
      <focus>yes</focus>
    </application>
  </applications>

</openbox_config>
